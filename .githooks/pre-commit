#!/bin/sh
# Pre-commit hook: run clang-format on staged C++/ObjC files.
# Only reformats files that are part of this commit.

CLANG_FORMAT=$(command -v clang-format 2>/dev/null)
if [ -z "$CLANG_FORMAT" ]; then
    echo "Warning: clang-format not found, skipping format check"
    exit 0
fi

# Get list of staged files (added/modified)
STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(cpp|h|mm)$' | grep -v '^third-party/')

if [ -z "$STAGED" ]; then
    exit 0
fi

# Format each staged file and re-stage
for file in $STAGED; do
    "$CLANG_FORMAT" -i "$file"
    git add "$file"
done

# Regenerate AONX protocol docs if the OpenAPI spec changed
SPEC_CHANGED=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^doc/aonx/openapi\.yaml$')

if [ -n "$SPEC_CHANGED" ]; then
    SCRIPT_DIR="$(git rev-parse --show-toplevel)/doc/aonx/build-docs.sh"
    if [ -x "$SCRIPT_DIR" ]; then
        "$SCRIPT_DIR"
        git add doc/aonx/index.html
    fi
fi
