# Observability Caddyfile (metrics server only).
# Proxies /grafana and /prometheus; redirects root to Grafana.
# For game servers, use Caddyfile.game instead.

# --- Global server options (must be first) ---
{
	servers :443 {
		timeouts {
			read_header 10s
			read_body   30s
			idle        120s
		}
	}
}

# Shared TLS configuration (DNS-01 for IPv6-only instances)
(tls_dns) {
	tls {
		dns route53
	}
}

# --- HTTP/REST API + Observability (port 443) ---
{$KAGAMI_DOMAIN} {
	import tls_dns

	# Layer 1: max request body 64KB (largest valid IC message is ~4KB)
	request_body {
		max_size 64KB
	}

	# Grafana (served from /grafana/, handles its own sub-path via GF_SERVER_SERVE_FROM_SUB_PATH)
	handle /grafana* {
		reverse_proxy 127.0.0.1:3000
	}

	# Prometheus (served from /prometheus/, configured via --web.external-url)
	handle /prometheus* {
		reverse_proxy 127.0.0.1:9090
	}

	# Root redirects to Grafana
	handle {
		redir / /grafana/ permanent
		respond "Not Found" 404
	}
}
