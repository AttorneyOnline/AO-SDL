  "title": "Kagami \u2014 Content Moderation",
  "uid": "kagami-moderation",
  "version": 12,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Check throughput (req/s, last 5m)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "description": "Sustained rate of ContentModerator::check() calls. This is the total moderation workload across IC and OOC, both protocols.",
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "rate(kagami_moderation_checks_total[5m])",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 20
              },
              {
                "color": "orange",
                "value": 100
              }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Mean check() latency",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "description": "Average time in ContentModerator::check() over the last 5 minutes, including all enabled layers and audit log fan-out. Watch this for drift after enabling Layer 2 (remote) or Layer 3 (embeddings).",
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "rate(kagami_moderation_check_nanoseconds_total[5m]) / rate(kagami_moderation_checks_total[5m])",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ns"
        }
      }
    },
    {
      "id": 3,
      "title": "Tracked IPIDs (heat > 0)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "description": "Count of clients currently carrying nonzero moderation heat. Decays over time as users stop offending.",
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "kagami_moderation_heat_tracked_ipids",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "orange",
                "value": 20
              },
              {
                "color": "red",
                "value": 50
              }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Active mutes",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "description": "IPIDs currently under an auto-mute entry (persisted in kagami.db). Drops as expires_at passes.",
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "kagami_moderation_muted_ipids",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 3
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Action mix (rate over 5m)",
      "type": "timeseries",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "description": "Rate of moderation decisions by action, stacked. Most traffic should sit on 'none'; escalation through log \u2192 censor \u2192 drop \u2192 mute \u2192 kick \u2192 ban indicates active abuse response.",
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "sum by (action) (rate(kagami_moderation_events_total[5m]))",
          "legendFormat": "{{action}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "stacking": {
              "mode": "normal"
            },
            "fillOpacity": 60
          },
          "unit": "ops"
        }
      }
    },
    {
      "id": 6,
      "title": "Channel split (rate over 5m)",
      "type": "timeseries",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "description": "IC vs OOC event split. A surge in IC events usually means a courtroom is being flooded; OOC is the more common chat path.",
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "sum by (channel) (rate(kagami_moderation_events_total[5m]))",
          "legendFormat": "{{channel}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "stacking": {
              "mode": "normal"
            },
            "fillOpacity": 60
          },
          "unit": "ops"
        }
      }
    },
    {
      "id": 7,
      "title": "Per-axis fire rate (5m)",
      "type": "timeseries",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 13
      },
      "description": "How often each moderation axis scores above its visibility floor. Helps tune HeatConfig weights \u2014 axes that fire often but produce nuisance actions probably need lower weights.",
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "sum by (axis) (rate(kagami_moderation_axis_fires_total[5m]))",
          "legendFormat": "{{axis}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      }
    },
    {
      "id": 8,
      "title": "Per-axis fire share (last 1h)",
      "type": "piechart",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 13
      },
      "description": "Relative distribution of axis fires over the last hour. A well-tuned deployment sees mostly visual_noise/link_risk/toxicity; hate and sexual_minors should be rare signals when they do hit.",
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "sum by (axis) (increase(kagami_moderation_axis_fires_total[1h]))",
          "legendFormat": "{{axis}}",
          "refId": "A"
        }
      ],
      "options": {
        "displayLabels": [
          "name",
          "percent"
        ],
        "pieType": "donut",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        }
      }
    },
    {
      "id": 9,
      "title": "Layer latency \u2014 mean (ns per call, 5m)",
      "type": "timeseries",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 22
      },
      "description": "Per-layer mean latency. unicode and urls are sub-millisecond rules-based layers. remote (OpenAI) is ~50-500ms when enabled. embeddings (llama.cpp) varies by model size \u2014 typically 10-50ms for bge-small.",
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "sum by (layer) (rate(kagami_moderation_layer_nanoseconds_total[5m])) / sum by (layer) (rate(kagami_moderation_layer_calls_total[5m]))",
          "legendFormat": "{{layer}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ns"
        }
      }
    },
    {
      "id": 10,
      "title": "Layer call rate (5m)",
      "type": "timeseries",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 22
      },
      "description": "How often each layer runs. Layers short-circuit when their config disables them, so this is a deployment sanity check: if the remote layer shows zero calls despite enabled=true, the API key is probably missing or empty.",
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "sum by (layer) (rate(kagami_moderation_layer_calls_total[5m]))",
          "legendFormat": "{{layer}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      }
    },
    {
      "id": 11,
      "title": "Remote classifier errors by cause (15m)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 31
      },
      "description": "Failures of the OpenAI moderation API, broken down by cause: transport (network/timeout), http_4xx (usually auth), http_5xx (upstream outage). With fail_open=true (default), errors are silently absorbed and this is the only way to notice.",
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "sum by (reason) (rate(kagami_moderation_remote_errors_total[5m]))",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      }
    },
    {
      "id": 12,
      "title": "Remote classifier error total (15m)",
      "type": "stat",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 31
      },
      "description": "Count of remote classifier failures in the last 15 minutes, across all causes. A persistent nonzero reading indicates a misconfigured API key or an OpenAI incident; the moderation stack keeps working because Layer 1 carries the decision.",
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "sum(increase(kagami_moderation_remote_errors_total[15m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 50
              }
            ]
          }
        }
      }
    },
    {
      "id": 13,
      "title": "Recent moderation events (parsed, CloudWatch / moderation stream)",
      "type": "table",
      "gridPos": {
        "h": 14,
        "w": 24,
        "x": 0,
        "y": 39
      },
      "description": "Structured view of the ModerationAuditLog CloudWatch sink, parsed out of the JSON payload. Columns: timestamp, action, channel, ipid, heat_after, reason, message_sample, and the per-axis scores that fired. Query uses CloudWatch Logs Insights regex parse on the JSON line \u2014 adjust the regexes in the expression if you add new axes.",
      "datasource": {
        "type": "cloudwatch",
        "uid": "cloudwatch"
      },
      "targets": [
        {
          "refId": "A",
          "queryMode": "Logs",
          "region": "default",
          "logGroups": [
            {
              "name": "/kagami/kagami-staging"
            }
          ],
          "expression": "fields @timestamp\n| filter @logStream = \"moderation\"\n| parse @message /\"action\":\"(?<action>[^\"]+)\"/\n| parse @message /\"channel\":\"(?<channel>[^\"]+)\"/\n| parse @message /\"ipid\":\"(?<ipid>[^\"]*)\"/\n| parse @message /\"heat_after\":(?<heat>[0-9.e+-]+)/\n| parse @message /\"reason\":\"(?<reason>[^\"]*)\"/\n| parse @message /\"message_sample\":\"(?<sample>[^\"]*)\"/\n| parse @message /\"visual_noise\":(?<visual_noise>[0-9.e+-]+)/\n| parse @message /\"link_risk\":(?<link_risk>[0-9.e+-]+)/\n| parse @message /\"slurs\":(?<slurs>[0-9.e+-]+)/\n| parse @message /\"toxicity\":(?<toxicity>[0-9.e+-]+)/\n| parse @message /\"hate\":(?<hate>[0-9.e+-]+)/\n| parse @message /\"sexual\":(?<sexual>[0-9.e+-]+)/\n| parse @message /\"sexual_minors\":(?<sexual_minors>[0-9.e+-]+)/\n| parse @message /\"violence\":(?<violence>[0-9.e+-]+)/\n| parse @message /\"self_harm\":(?<self_harm>[0-9.e+-]+)/\n| parse @message /\"semantic_echo\":(?<semantic_echo>[0-9.e+-]+)/\n| display @timestamp, action, channel, ipid, heat, reason, sample, visual_noise, link_risk, slurs, toxicity, hate, sexual, sexual_minors, violence, self_harm, semantic_echo\n| sort @timestamp desc\n| limit 200"
        }
      ],
      "options": {
        "showHeader": true,
        "footer": {
          "show": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            }
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "action"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 90
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "none": {
                        "color": "text",
                        "index": 0
                      }
                    }
                  },
                  {
                    "type": "value",
                    "options": {
                      "log": {
                        "color": "blue",
                        "index": 1
                      }
                    }
                  },
                  {
                    "type": "value",
                    "options": {
                      "censor": {
                        "color": "yellow",
                        "index": 2
                      }
                    }
                  },
                  {
                    "type": "value",
                    "options": {
                      "drop": {
                        "color": "orange",
                        "index": 3
                      }
                    }
                  },
                  {
                    "type": "value",
                    "options": {
                      "mute": {
                        "color": "orange",
                        "index": 4
                      }
                    }
                  },
                  {
                    "type": "value",
                    "options": {
                      "kick": {
                        "color": "red",
                        "index": 5
                      }
                    }
                  },
                  {
                    "type": "value",
                    "options": {
                      "ban": {
                        "color": "red",
                        "index": 6
                      }
                    }
                  },
                  {
                    "type": "value",
                    "options": {
                      "perma_ban": {
                        "color": "dark-red",
                        "index": 7
                      }
                    }
                  }
                ]
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "channel"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 70
              }
            ]
          },
          {
            "matcher": {
