    {
      "id": 15,
      "title": "Embedding model \u2014 tokens/sec (5m)",
      "type": "stat",
      "description": "Token throughput of the llama.cpp embedding backend. For bge-small-en on arm64 CPU, expect ~200-500 tok/s sustained; lower means the backend is under-fed (most traffic isn't getting clustered) or the model is CPU-bound. Use alongside the per-call token count to sanity-check traffic shape.",
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 59
      },
      "targets": [
        {
          "expr": "rate(kagami_moderation_embedding_tokens_total[5m])",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "gray",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      }
    },
    {
      "id": 16,
      "title": "Embedding \u2014 mean tokens / call",
      "type": "stat",
      "description": "Average token count per embedding call. For a chat server this tracks message length in tokens; a sudden spike usually means someone's trying to maximize model cost or exfiltrate via long inputs.",
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 59
      },
      "targets": [
        {
          "expr": "rate(kagami_moderation_embedding_tokens_total[5m]) / rate(kagami_moderation_layer_calls_total{layer=\"embeddings\"}[5m])",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1
        }
      }
    },
    {
      "id": 17,
      "title": "Embedding \u2014 decode time / token (ns)",
      "type": "stat",
      "description": "Nanoseconds of llama_decode (model forward pass) per token processed. This is the raw cost of the embedding model independent of tokenizer overhead. For bge-small on arm64 CPU expect 50-200 \u00b5s/tok; sudden growth indicates CPU contention.",
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 12,
        "y": 59
      },
      "targets": [
        {
          "expr": "rate(kagami_moderation_embedding_decode_nanoseconds_total[5m]) / rate(kagami_moderation_embedding_tokens_total[5m])",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ns"
        }
      }
    },
    {
      "id": 18,
      "title": "Semantic cluster fires (15m)",
      "type": "stat",
      "description": "Count of times the Layer 3 semantic detector crossed cluster_threshold distinct IPIDs in its sliding window. Nonzero means a coordinated paraphrase campaign was detected.",
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 18,
        "y": 59
      },
      "targets": [
        {
          "expr": "sum(increase(kagami_moderation_semantic_cluster_fires_total[15m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          }
        }
      }
    },
    {
      "id": 19,
      "title": "Embedding decode vs tokenize breakdown (5m)",
      "type": "timeseries",
      "description": "Where time is being spent inside the embedding backend: tokenize (BPE/WordPiece) vs decode (model forward pass). Decode should dominate for any non-trivial input; tokenize time spiking without decode moving usually means unusually large inputs.",
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 64
      },
      "targets": [
        {
          "expr": "rate(kagami_moderation_embedding_tokenize_nanoseconds_total[5m])",
          "legendFormat": "tokenize",
          "refId": "A"
        },
        {
          "expr": "rate(kagami_moderation_embedding_decode_nanoseconds_total[5m])",
          "legendFormat": "decode",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "stacking": {
              "mode": "normal"
            },
            "fillOpacity": 40
          },
          "unit": "nsps"
        }
      }
    },
    {
      "id": 20,
      "title": "Embedding backend errors (5m)",
      "type": "timeseries",
      "description": "Failures from EmbeddingBackend::embed by cause: not_ready (backend not loaded), empty_text (caller bug), tokenize (vocab mismatch), decode (llama.cpp failure), other. A persistent nonzero reading indicates the embedding layer is silently degrading and Layer 3 scoring is stalled.",
