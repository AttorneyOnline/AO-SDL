    {
      "type": "table",
      "title": "Session List",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 71
      },
      "targets": [
        {
          "expr": "kagami_session_idle_seconds{instance=~\"$instance\"}",
          "format": "table",
          "instant": true,
          "refId": "idle",
          "interval": "100ms"
        },
        {
          "expr": "kagami_session_bytes_sent{instance=~\"$instance\"}",
          "format": "table",
          "instant": true,
          "refId": "bytes_out",
          "interval": "100ms"
        },
        {
          "expr": "kagami_session_bytes_received{instance=~\"$instance\"}",
          "format": "table",
          "instant": true,
          "refId": "bytes_in",
          "interval": "100ms"
        },
        {
          "expr": "kagami_session_packets_sent{instance=~\"$instance\"}",
          "format": "table",
          "instant": true,
          "refId": "pkts_out",
          "interval": "100ms"
        },
        {
          "expr": "kagami_session_packets_received{instance=~\"$instance\"}",
          "format": "table",
          "instant": true,
          "refId": "pkts_in",
          "interval": "100ms"
        }
      ],
      "transformations": [
        {
          "id": "joinByField",
          "options": {
            "byField": "session_id",
            "mode": "outer"
          }
        },
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "pattern": "session_id|display_name 1|protocol 1|area 1|character 1|Value #idle|Value #bytes_out|Value #bytes_in|Value #pkts_out|Value #pkts_in"
            }
          }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "display_name 1": "name",
              "protocol 1": "protocol",
              "area 1": "area",
              "character 1": "character",
              "Value #idle": "idle",
              "Value #bytes_out": "bytes_out",
              "Value #bytes_in": "bytes_in",
              "Value #pkts_out": "pkts_out",
              "Value #pkts_in": "pkts_in"
            },
            "indexByName": {
              "session_id": 0,
              "name": 1,
              "character": 2,
              "protocol": 3,
              "area": 4,
              "bytes_out": 5,
              "bytes_in": 6,
              "pkts_out": 7,
              "pkts_in": 8,
              "idle": 9
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "bytes_out"
            },
            "properties": [
              {
                "id": "unit",
                "value": "bytes"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "bytes_in"
            },
            "properties": [
              {
                "id": "unit",
                "value": "bytes"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "idle"
            },
            "properties": [
              {
                "id": "unit",
                "value": "s"
              }
            ]
          }
        ]
      }
    },
